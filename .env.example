# AI Provider — switch between ollama (local), openai (production), anthropic
AI_PROVIDER=openai

# Ollama (local development) — Ollama exposes an OpenAI-compatible API at /v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# OpenAI (production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Upstash Redis — chat rate-limit storage (10 messages per IP per hour).
# Get keys at https://console.upstash.com/redis (free tier is plenty).
# When unset, the rate-limit check is skipped entirely (acceptable for local dev,
# NOT acceptable for production — both keys must be present in Vercel env vars).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
