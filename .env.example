# AI Provider — switch between ollama (local), openai (production), anthropic
AI_PROVIDER=openai

# Ollama (local development) — Ollama exposes an OpenAI-compatible API at /v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# OpenAI (production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
